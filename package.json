{
  "name": "backbone",
  "version": "0.1.13",
  "description": "Backbone — a menu-bar app that watches your posture via webcam and reminds you to move.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "fetch-model": "node scripts/fetch-model.js",
    "make-icons": "node scripts/make-icon-assets.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "release": "npm version patch && git push --follow-tags",
    "notarize": "node scripts/notarize.js",
    "ship": "npm run dist:mac && npm run notarize && npm run publish:mac",
    "publish:mac": "electron-builder --mac --publish always --prepackaged dist/mac-arm64/Backbone.app"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "qrcode": "^1.5.4"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "io.milkshake.backbone",
    "productName": "Backbone",
    "asar": false,
    "publish": [
      {
        "provider": "github",
        "owner": "emailtarun",
        "repo": "backbone",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "lib/**",
      "src/**",
      "vendor/**",
      "models/**",
      "node_modules/**"
    ],
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "icon": "build/icon.icns",
      "identity": "Tarunbir Brar (NRV5HN2Y4B)",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSCameraUsageDescription": "Backbone uses your webcam on-device to detect your sitting posture. No video is recorded or sent anywhere.",
        "LSUIElement": 1
      },
      "notarize": false
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
